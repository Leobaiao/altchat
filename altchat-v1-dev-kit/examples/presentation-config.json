{
  "client": {
    "title": "AltDesk Assistente",
    "subtitle": "Atendimento Online",
    "avatarUrl": "",
    "logoUrl": ""
  },
  "window": {
    "mode": "popup",
    "width": 420,
    "height": 680,
    "minWidth": 320,
    "minHeight": 500,
    "resizable": true
  },
  "theme": {
    "mode": "light",
    "primaryColor": "#2563EB",
    "secondaryColor": "#111827",
    "backgroundColor": "#FFFFFF",
    "textColor": "#111827"
  },
  "behavior": {
    "autoOpen": true,
    "showWelcome": true,
    "typingIndicator": true,
    "persistSession": true
  },
  "capabilities": {
    "text": true,
    "file": true,
    "image": true,
    "audio": false,
    "video": false
  },
  "session": {
    "timeoutSeconds": 1800,
    "keepAlive": true
  }
}
